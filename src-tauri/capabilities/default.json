{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "http:default",
    "opener:default",
    {
      "identifier": "http:allow-fetch",
      "allow": [
        { "url": "http://localhost:**" },
        { "url": "http://127.0.0.1:**" },
        { "url": "https://**" }
      ]
    },
    {
      "identifier": "opener:allow-open-url",
      "allow": [
        { "url": "https://**" },
        { "url": "http://**" }
      ]
    }
  ]
}
